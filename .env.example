# Database Configuration
# Local format: postgres://<user>:<password>@localhost:5432/hospitals
# Docker Compose internal format: postgres://<user>:<password>@db:5432/hospitals
DATABASE_URL=postgres://postgres:password@localhost:5432/findmehospital?sslmode=disable

# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# CORS Configuration
# Comma-separated list of allowed origins
# Use '*' for development or specific URLs for production
CORS_ORIGIN=*
